# Environment Configuration for M35 Backend
# Copy this to .env in the project root

# MongoDB Configuration
MONGO_DB_URI=mongodb://localhost:27017
MONGO_DB=therapy_database

# Dashboard MongoDB keys (Module F35)
M35_MONGODB_URI=mongodb://localhost:27017
M35_MONGODB_DB=m35_therapy

# M35 API Configuration
M35_API_BASE_URL=http://localhost:5000
M35_API_PORT=5000

# Application Environment
DEBUG=True
ENVIRONMENT=development

# Flask Configuration
FLASK_APP=backend/api_m35.py
FLASK_ENV=development
